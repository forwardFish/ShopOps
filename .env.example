APP_ENV=local
SHOP_ID=taobao_shop_001
SHOP_NAME=淘宝店铺A

SHOP_PLATFORM=taobao

# Current MVP defaults. Use crawler + Qianniu PC, not Taobao Open Platform API.
ORDER_SOURCE=crawler
PROMOTION_SOURCE=qianniu_pc
FETCH_INTERVAL_SECONDS=600
USE_MOCK_COLLECTORS=true
STORAGE_BACKEND=local
EVIDENCE_DIR=docs/live-evidence

# Local Feishu Bitable double and pending replay cache.
LOCAL_FEISHU_PATH=cache/local_feishu.json
PENDING_RECORDS_PATH=cache/pending_records.jsonl

# Reserved for future ORDER_SOURCE=api use. Leave blank for current crawler scope.
TAOBAO_APP_KEY=
TAOBAO_APP_SECRET=
TAOBAO_SESSION_KEY=
TAOBAO_API_URL=https://eco.taobao.com/router/rest
TAOBAO_ORDER_LIST_METHOD=taobao.open.trades.sold.get
TAOBAO_ORDER_DETAIL_METHOD=taobao.open.trade.get

# ORDER_SOURCE=api + SHOP_PLATFORM=pinduoduo.
PDD_CLIENT_ID=
PDD_CLIENT_SECRET=
PDD_ACCESS_TOKEN=
PDD_API_URL=https://gw-api.pinduoduo.com/api/router
PDD_ORDER_LIST_TYPE=pdd.order.number.list.increment.get
PDD_ORDER_DETAIL_TYPE=pdd.order.information.get

# ORDER_SOURCE=api + SHOP_PLATFORM=doudian.
DOUDIAN_APP_KEY=
DOUDIAN_APP_SECRET=
DOUDIAN_ACCESS_TOKEN=
DOUDIAN_API_URL=https://openapi-fxg.jinritemai.com
DOUDIAN_SIGN_METHOD=hmac-sha256
DOUDIAN_ALLIANCE_ORDER_IDS=

# OceanEngine / Qianchuan ad report APIs.
OCEANENGINE_MARKETING_APP_ID=
OCEANENGINE_MARKETING_APP_SECRET=
QIANCHUAN_APP_ID=
QIANCHUAN_APP_SECRET=
QIANCHUAN_ACCESS_TOKEN=
QIANCHUAN_REFRESH_TOKEN=
QIANCHUAN_AUTH_CODE=
QIANCHUAN_ADVERTISER_ID=
OCEANENGINE_API_URL=https://api.oceanengine.com
OCEANENGINE_AUTH_API_URL=https://ad.oceanengine.com

# ORDER_SOURCE=api + SHOP_PLATFORM=wechat_channels.
# WECHAT_CHANNELS_ACCESS_TOKEN can be left blank if app id/secret can fetch a token.
WECHAT_CHANNELS_APP_ID=
WECHAT_CHANNELS_APP_SECRET=
WECHAT_CHANNELS_ACCESS_TOKEN=
WECHAT_CHANNELS_API_URL=https://api.weixin.qq.com

# ORDER_SOURCE=jushuitan. This keeps direct platform API mode above intact.
JUSHUITAN_APP_KEY=
JUSHUITAN_APP_SECRET=
JUSHUITAN_PARTNER_ID=
JUSHUITAN_PARTNER_KEY=
JUSHUITAN_TOKEN=
JUSHUITAN_API_URL=https://open.erp321.com/api/open/query.aspx
JUSHUITAN_ORDER_QUERY_METHOD=orders.single.query
JUSHUITAN_INFLUENCER_QUERY_METHOD=doudian.alliance.kol.orders.query
JUSHUITAN_SHOP_IDS=
JUSHUITAN_SHOP_ID_TMALL=
JUSHUITAN_SHOP_ID_DOUYIN=
JUSHUITAN_SHOP_ID_WECHAT_CHANNELS=
JUSHUITAN_SHOP_ID_PINDUODUO=
JUSHUITAN_PAGE_SIZE=100

# Required for Taobao/Tmall Qimen order list API: jushuitan.order.list.query.
# Get these from the Jushuitan/Taobao Qimen authorization binding flow.
JUSHUITAN_QIMEN_URL=http://a1q40taq0j.api.taobao.com/router/qm
JUSHUITAN_QIMEN_APP_KEY=
JUSHUITAN_QIMEN_APP_SECRET=
JUSHUITAN_QIMEN_CUSTOMER_ID=
JUSHUITAN_QIMEN_SESSION=
JUSHUITAN_QIMEN_TARGET_APP_KEY=23060081
JUSHUITAN_QIMEN_ORDER_LIST_METHOD=jushuitan.order.list.query

# Current live promotion-only Cookie API collection.
# Copy these from the successful Qianniu PC promotion request when running scripts/run_promotion_api_to_feishu.py.
TAOBAO_PROMOTION_COOKIE=
TAOBAO_PROMOTION_CSRF_ID=
TAOBAO_PROMOTION_LOGIN_POINT_ID=

# Qianniu PC must already be running and logged in on this Windows desktop.
QIANNIU_CDP_URL=http://127.0.0.1:9222

# Real Feishu values are required only for live Bitable write/readback verification.
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_APP_TOKEN=
FEISHU_WEBHOOK=
FEISHU_PLATFORM_NAME=千牛淘宝

# Real Feishu Bitable table IDs. Created by scripts/bootstrap_feishu_tables.py.
FEISHU_TABLE_SYSTEM_CONFIG=system_config
FEISHU_TABLE_SHOP_CONFIG=shop_config
FEISHU_TABLE_MONITOR_SNAPSHOT=monitor_snapshot
FEISHU_TABLE_ORDERS_RAW=orders_raw
FEISHU_TABLE_PROMOTION_SNAPSHOT=promotion_snapshot
FEISHU_TABLE_METRICS_10MIN=metrics_10min
FEISHU_TABLE_TASK_LOG=task_run_log
FEISHU_TABLE_ALERT_LOG=alert_log
FEISHU_TABLE_DAILY_REPORT=daily_report
FEISHU_TABLE_DOUYIN_INFLUENCER_COMMISSION=douyin_influencer_commission
SHOPOPS_DOUYIN_INFLUENCER_EXCEL_TABLE_ID=

# Required Chinese display names for Feishu tables.
FEISHU_TABLE_SYSTEM_CONFIG_NAME=系统配置表
FEISHU_TABLE_SHOP_CONFIG_NAME=店铺配置表
FEISHU_TABLE_MONITOR_SNAPSHOT_NAME=实时监控快照表
FEISHU_TABLE_ORDERS_RAW_NAME=订单明细原始表-千牛淘宝
FEISHU_TABLE_PROMOTION_SNAPSHOT_NAME=推广数据表-千牛淘宝
FEISHU_TABLE_METRICS_10MIN_NAME=十分钟指标表
FEISHU_TABLE_TASK_LOG_NAME=任务运行日志表
FEISHU_TABLE_ALERT_LOG_NAME=告警日志表
FEISHU_TABLE_DAILY_REPORT_NAME=每日报告表
FEISHU_TABLE_DOUYIN_INFLUENCER_COMMISSION_NAME=抖音达人佣金明细表

# Existing Feishu Base source tables for SQL-like dynamic summaries.
SHOPOPS_DATA_CENTER_APP_TOKEN=
SHOPOPS_ORDER_TABLE_ID=
SHOPOPS_AD_TABLE_ID=
SHOPOPS_COMMISSION_TABLE_ID=
SHOPOPS_DYNAMIC_SUMMARY_TABLE_ID=
SHOPOPS_FORMULA_SUMMARY_TABLE_ID=
SHOPOPS_FORMULA_TOTAL_SUMMARY_TABLE_ID=
SHOPOPS_DASHBOARD_KPI_TABLE_ID=

ALERT_TOTAL_COST=500
ALERT_MIN_ROI=1.0
ALERT_ORDER_DROP_RATE=0.5
ALERT_DEDUP_MINUTES=30
DAILY_REPORT_TIME=23:50
